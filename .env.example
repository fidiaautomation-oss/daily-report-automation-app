# Google認証（サービスアカウントのJSONキーファイルパス）
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Google Drive フォルダID
DRIVE_ROOT_FOLDER_ID=your_folder_id_here

# 担当案件DBスプレッドシートID
ASSIGNMENT_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Ads Scripts の出力先スプレッドシートID（google_ads シートを読込）
GOOGLE_ADS_SHEET_ID=your_google_ads_sheet_id_here

# Yahoo広告API（OAuth2）
# client_id / client_secret は全アカウント共通（1セット）
# REFRESH_TOKENS はビジネスIDごとのリフレッシュトークンをカンマ区切りで設定
#   （1トークンで多数の広告アカウントにアクセス可能）
YAHOO_ADS_CLIENT_ID=your_client_id_here
YAHOO_ADS_CLIENT_SECRET=your_client_secret_here
YAHOO_ADS_REFRESH_TOKENS=refresh_token_A,refresh_token_B,refresh_token_C
# YAHOO_ADS_ACCOUNT_IDS は手動設定不要。
# `python -m phase1.yahoo_ads_fetcher discover` 実行で自動取得・反映される（可視化用）。
# レポート取得時も毎回アカウントを自動発見するため、この行が無くても動作する。

# ASP設定
ASP_A_URL=https://example-asp.com
ASP_A_USERNAME=your_username
ASP_A_PASSWORD=your_password
